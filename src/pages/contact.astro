---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticleCard from "../components/ArticleCard.astro";
---

<Layout title="Contact | Krishna's Knowledge Journal">

<Header />

<main>

<section>

<h2>Get in Touch</h2>

<p>

Thank you for visiting Krishna's Knowledge Journal.

Whether you have a question, would like to suggest a topic, or wish to provide feedback, I'd be glad to hear from you.

</p>

<ArticleCard
title="Email"
text="iamkgp27@gmail.com"
/>

</section>

<section>

<h2>Topics You Can Contact Me About</h2>

<div class="cards">

<ArticleCard
title="Questions"
text="Ask questions related to published articles."
/>

<ArticleCard
title="Suggestions"
text="Recommend future topics you would like to read."
/>

<ArticleCard
title="Feedback"
text="Share ideas that can improve the journal."
/>

</div>

</section>

</main>

<Footer />

</Layout>